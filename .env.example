# .env.example — copy to .env for local development
# Never commit .env to git

# ── Database ─────────────────────────────────────────────────
# Leave blank for local SQLite (auto-created as solvit_dev.db)
# Paste your Render PostgreSQL connection string for cloud testing
DATABASE_URL=

# ── Microsoft Graph ──────────────────────────────────────────
# Get from: https://entra.microsoft.com → App registrations
# Steps:
#   1. New registration → any name (e.g. "Solvit Mailer")
#   2. API permissions → Add → Microsoft Graph → Application permissions:
#        Mail.Send  Mail.Read  Mail.ReadBasic
#   3. Grant admin consent (button at top of permissions page)
#   4. Certificates & secrets → New client secret → copy Value immediately
#   5. Overview page → copy Tenant ID and Application (client) ID
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_SENDER_UPN=cs-team@solvit.co.ke

# ── Zoho Analytics ───────────────────────────────────────────
# Get from: https://api-console.zoho.com
# Steps:
#   1. Create a "Self Client"
#   2. Generate token with scopes: ZohoAnalytics.data.read,ZohoAnalytics.metadata.read
#   3. Exchange grant code for refresh token (one-time, see ZOHO_SETUP.md)
#   4. Find Workspace ID and View ID in your Zoho Analytics URL
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_WORKSPACE_ID=
ZOHO_VIEW_ID=
ZOHO_DC=com

# ── Data source ───────────────────────────────────────────────
# "csv"  → manual upload via portal (default)
# "zoho" → auto-sync from Zoho Analytics every 15 min
DATA_SOURCE=csv

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=
ADMIN_EMAIL=support@solvit.co.ke
ADMIN_PASSWORD=S0lv1tAdmin!

# ── App ──────────────────────────────────────────────────────
PORT=8000
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000
